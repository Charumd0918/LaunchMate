# MONGO_URI: Connection string for MongoDB (Atlas or local)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/launchmate_db?retryWrites=true&w=majority

# GEMINI_API_KEY: Your Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# JWT_SECRET: Secret key for signing authentication tokens
JWT_SECRET=super-secret-key-change-me

# FRONTEND_URL: The URL where the frontend is hosted (for CORS)
FRONTEND_URL=http://localhost:5173

# VITE_API_URL: The URL where the backend API is hosted (for frontend build)
VITE_API_URL=http://localhost:8000/api
